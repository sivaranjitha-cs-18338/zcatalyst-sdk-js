{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**/*",
        "package.json"
      ],
      "outputs": [
        "dist-*/**"
      ]
    },
    "docs":{
      "dependsOn": [
        "^docs"
      ],
      "inputs": [
        "src/**/*",
        "package.json"
      ]
    },
    "test": {
      "cache": false,
      "inputs": [
        "src/**/*",
        "tests/**/*",
        "jest.config.*"
      ],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "format": {
      "outputs": []
    }
  }
}
